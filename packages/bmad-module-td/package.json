{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@wvanderen/bmad-module-td",
  "version": "0.1.12",
  "description": "BMAD expansion module for td CLI integration - td provides state, BMAD provides structure",
  "keywords": [
    "bmad",
    "td",
    "task-management",
    "cli",
    "integration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmad-code-org/bmad-module-td.git"
  },
  "license": "MIT",
  "author": "BMad Method",
  "main": "",
  "bin": {},
  "scripts": {
    "sync:module": "node ../../scripts/sync-td-integration.mjs --source-dir packages/bmad-module-td",
    "sync:check": "node ../../scripts/sync-td-integration.mjs --check --source-dir packages/bmad-module-td",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,json,yaml}\"",
    "format:fix": "prettier --write \"**/*.{js,cjs,mjs,json,yaml}\"",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "pack": "npm pack",
    "release": "npm run release:patch",
    "release:major": "npm version major",
    "release:minor": "npm version minor",
    "release:patch": "npm version patch",
    "release:prerelease": "npm version prerelease",
    "publish:package": "npm publish --access public",
    "publish:check": "npm pack --dry-run",
    "test": "npm run sync:check && npm run lint && npm run format:check"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "markdownlint-cli2": "^0.19.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "data",
    "templates",
    "tools",
    "workflows",
    "module-help.csv",
    "module.yaml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bmad": {
    "moduleType": "expansion",
    "requires": [
      "bmm"
    ],
    "provides": [
      "td-integration"
    ]
  }
}
