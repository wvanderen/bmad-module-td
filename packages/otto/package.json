{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@wvanderen/otto",
  "version": "0.0.1",
  "description": "Otto, the Pi-native operating layer for BMAD and td workflows",
  "keywords": [
    "bmad",
    "td",
    "pi",
    "pi-package",
    "otto",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmad-code-org/bmad-module-td.git"
  },
  "license": "MIT",
  "author": "BMad Method",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "skills",
    "otto.svg"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "sync:source": "node ../../scripts/sync-otto.mjs",
    "prepack": "npm run sync:source",
    "pack": "npm pack",
    "release": "npm run release:patch",
    "release:major": "npm version major",
    "release:minor": "npm version minor",
    "release:patch": "npm version patch",
    "release:prerelease": "npm version prerelease",
    "publish:package": "npm publish --access public",
    "publish:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
