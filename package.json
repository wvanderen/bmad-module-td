{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "bmad-td-monorepo",
  "version": "0.1.12",
  "description": "Monorepo for BMAD td module and Otto Pi extension",
  "keywords": [
    "bmad",
    "td",
    "task-management",
    "cli",
    "integration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmad-code-org/bmad-module-td.git"
  },
  "license": "MIT",
  "author": "BMad Method",
  "private": true,
  "scripts": {
    "check:otto-package": "node scripts/check-otto-package-assets.mjs",
    "check:otto-result": "node scripts/check-otto-result-contract.mjs",
    "score:dry-run": "node scripts/score-dry-run.mjs",
    "score:otto-run": "node scripts/score-otto-run.mjs",
    "sync:module": "node scripts/sync-td-integration.mjs --source-dir packages/bmad-module-td",
    "sync:check": "node scripts/sync-td-integration.mjs --check --source-dir packages/bmad-module-td",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,json,yaml}\"",
    "format:fix": "prettier --write \"**/*.{js,cjs,mjs,json,yaml}\"",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "pack:module": "npm pack --workspace @wvanderen/bmad-module-td",
    "release:module": "npm run release:module:patch",
    "release:module:major": "npm version major --workspace @wvanderen/bmad-module-td",
    "release:module:minor": "npm version minor --workspace @wvanderen/bmad-module-td",
    "release:module:patch": "npm version patch --workspace @wvanderen/bmad-module-td",
    "release:module:prerelease": "npm version prerelease --workspace @wvanderen/bmad-module-td",
    "publish:module": "npm publish --workspace @wvanderen/bmad-module-td --access public",
    "publish:module:check": "npm pack --dry-run --workspace @wvanderen/bmad-module-td",
    "release:module:patch:publish": "npm run release:module:patch && npm run publish:module",
    "release:module:minor:publish": "npm run release:module:minor && npm run publish:module",
    "release:module:major:publish": "npm run release:module:major && npm run publish:module",
    "release:module:prerelease:publish": "npm run release:module:prerelease && npm run publish:module",
    "pack:otto": "npm pack --workspace @wvanderen/otto",
    "release:otto": "npm run release:otto:patch",
    "release:otto:major": "npm version major --workspace @wvanderen/otto",
    "release:otto:minor": "npm version minor --workspace @wvanderen/otto",
    "release:otto:patch": "npm version patch --workspace @wvanderen/otto",
    "release:otto:prerelease": "npm version prerelease --workspace @wvanderen/otto",
    "publish:otto": "npm publish --workspace @wvanderen/otto --access public",
    "publish:otto:check": "npm pack --dry-run --workspace @wvanderen/otto",
    "release:otto:patch:publish": "npm run release:otto:patch && npm run publish:otto",
    "release:otto:minor:publish": "npm run release:otto:minor && npm run publish:otto",
    "release:otto:major:publish": "npm run release:otto:major && npm run publish:otto",
    "release:otto:prerelease:publish": "npm run release:otto:prerelease && npm run publish:otto",
    "pack:autopilot": "npm run pack:otto",
    "release:autopilot": "npm run release:otto",
    "release:autopilot:major": "npm run release:otto:major",
    "release:autopilot:minor": "npm run release:otto:minor",
    "release:autopilot:patch": "npm run release:otto:patch",
    "release:autopilot:prerelease": "npm run release:otto:prerelease",
    "publish:autopilot": "npm run publish:otto",
    "publish:autopilot:check": "npm run publish:otto:check",
    "release:autopilot:patch:publish": "npm run release:otto:patch:publish",
    "release:autopilot:minor:publish": "npm run release:otto:minor:publish",
    "release:autopilot:major:publish": "npm run release:otto:major:publish",
    "release:autopilot:prerelease:publish": "npm run release:otto:prerelease:publish",
    "release:check": "npm run sync:check && npm run publish:module:check && npm run publish:otto:check",
    "test": "npm run sync:check && npm run check:otto-result && npm run check:otto-package && npm run lint && npm run format:check"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "eslint": "^10.0.2",
    "markdownlint-cli2": "^0.19.1",
    "prettier": "^3.7.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": []
}
