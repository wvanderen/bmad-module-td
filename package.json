{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "bmad-td-monorepo",
  "version": "0.1.12",
  "description": "Monorepo for BMAD td module and Pi autopilot",
  "keywords": [
    "bmad",
    "td",
    "task-management",
    "cli",
    "integration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmad-code-org/bmad-module-td.git"
  },
  "license": "MIT",
  "author": "BMad Method",
  "private": true,
  "scripts": {
    "sync:module": "node scripts/sync-td-integration.mjs --source-dir packages/bmad-module-td",
    "sync:check": "node scripts/sync-td-integration.mjs --check --source-dir packages/bmad-module-td",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,json,yaml}\"",
    "format:fix": "prettier --write \"**/*.{js,cjs,mjs,json,yaml}\"",
    "lint": "eslint . --ext .js,.cjs,.mjs,.yaml --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.cjs,.mjs,.yaml --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "release:module": "npm run release:module:patch",
    "release:module:major": "npm version major --workspace @wvanderen/bmad-module-td",
    "release:module:minor": "npm version minor --workspace @wvanderen/bmad-module-td",
    "release:module:patch": "npm version patch --workspace @wvanderen/bmad-module-td",
    "release:module:prerelease": "npm version prerelease --workspace @wvanderen/bmad-module-td",
    "publish:module": "npm publish --workspace @wvanderen/bmad-module-td --access public",
    "release:module:patch:publish": "npm run release:module:patch && npm run publish:module",
    "release:module:minor:publish": "npm run release:module:minor && npm run publish:module",
    "release:module:major:publish": "npm run release:module:major && npm run publish:module",
    "pack:autopilot": "npm pack --workspace @wvanderen/pi-bmad-autopilot",
    "test": "npm run sync:check && npm run lint && npm run format:check"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "prettier": "^3.7.4",
    "markdownlint-cli2": "^0.19.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": []
}
